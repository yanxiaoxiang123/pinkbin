{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Pinkbin",
  "version": "0.1.2",
  "identifier": "dev.pinkbin.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "windows": [
      {
        "title": "Pinkbin",
        "label": "main",
        "width": 1280,
        "height": 800,
        "minWidth": 960,
        "minHeight": 600,
        "resizable": true,
        "dragDropEnabled": false
      }
    ],
    "security": { "csp": null }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "Utility",
    "shortDescription": "Disk analyzer with AI advisor and per-app cleanup scaffolds",
    "longDescription": "Pinkbin scans your disk, walks you through every large folder, and lets you safely clean caches with per-app scaffolds and an AI advisor.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "../../../scaffolds": "scaffolds"
    }
  }
}
